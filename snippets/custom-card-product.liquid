{% comment %}
  Renders a custom product card based on print design.
  Accepts:
  - card_product: {Object} Product Liquid object
  - section_id: {String}
{% endcomment %}
{%- if card_product and card_product != empty -%}
  {%- liquid
    assign ratio = 1
    if card_product.featured_media
      assign ratio = card_product.featured_media.aspect_ratio
    endif

    assign discount_percentage = 0
    if card_product.compare_at_price > card_product.price
      assign discount_percentage = card_product.compare_at_price | minus: card_product.price | times: 100.0 | divided_by: card_product.compare_at_price | round
    endif

    assign installment_price = card_product.price | divided_by: 6
  -%}
  
  <custom-card-variants class="custom-card-wrapper">
    <div class="custom-card">
      <div class="custom-card-media-wrapper" style="padding-bottom: 100%;">
        <div class="custom-card-media">
          {%- if card_product.featured_media -%}
            <img
              srcset="
                {%- if card_product.featured_media.width >= 165 -%}{{ card_product.featured_media | image_url: width: 165 }} 165w,{%- endif -%}
                {%- if card_product.featured_media.width >= 360 -%}{{ card_product.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
                {%- if card_product.featured_media.width >= 533 -%}{{ card_product.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
                {{ card_product.featured_media | image_url }} {{ card_product.featured_media.width }}w
              "
              src="{{ card_product.featured_media | image_url: width: 533 }}"
              sizes="(min-width: 1200px) 267px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
              alt="{{ card_product.featured_media.alt | escape }}"
              class="motion-reduce"
              loading="lazy"
              width="{{ card_product.featured_media.width }}"
              height="{{ card_product.featured_media.height }}"
            >
          {%- else -%}
            {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>

        {%- if discount_percentage > 0 -%}
          <div class="custom-card-badge">{{ discount_percentage }}% OFF</div>
        {%- endif -%}
        
        <div class="custom-card-favorite">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="icon icon-heart">
             <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </div>

        <div class="custom-card-hover-overlay">
          <div class="custom-card-sizes-container">
            <span class="custom-card-sizes-title">Selecione um tamanho</span>
            <div class="custom-card-sizes-list">
              {%- for variant in card_product.variants -%}
                <button type="button" class="size-option" data-variant-id="{{ variant.id }}" data-url="{{ variant.url }}" {% unless variant.available %}disabled{% endunless %}>
                  {{ variant.title }}
                </button>
              {%- endfor -%}
            </div>
          </div>
          <div class="custom-card-quick-add">
            {%- assign product_form_id = 'quick-add-' | append: section_id | append: card_product.id -%}
            <product-form>
              {%- form 'product', card_product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                <input type="hidden" name="id" value="{{ card_product.selected_or_first_available_variant.id }}" class="product-variant-id" disabled>
                <button type="submit" name="add" class="custom-quick-add-submit" aria-haspopup="dialog" disabled>
                  <span>Adicionar à sacola</span>
                  {%- render 'loading-spinner' -%}
                </button>
              {%- endform -%}
            </product-form>
          </div>
        </div>
      </div>

      <div class="custom-card-info">
        <h3 class="custom-card-title">
          <a href="{{ card_product.url }}" class="full-unstyled-link product-link">
            {{ card_product.title | escape }}
          </a>
        </h3>
        <div class="custom-card-price-wrapper">
          <span class="custom-card-price">{{ card_product.price | money }}</span>
          {%- if card_product.compare_at_price > card_product.price -%}
            <span class="custom-card-compare-price">{{ card_product.compare_at_price | money }}</span>
          {%- endif -%}
        </div>
        <div class="custom-card-installments">
          ou 6x de {{ installment_price | money }} sem juros
        </div>
      </div>
    </div>
  </custom-card-variants>
{%- endif -%}
