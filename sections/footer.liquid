{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer class="footer ec-footer color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="footer__content-top page-width ec-footer-top">
    {%- if section.blocks.size > 0 -%}
      <div class="ec-footer-grid">
        {%- for block in section.blocks -%}
          <div class="ec-footer-block ec-footer-block--{{ block.type }}" {{ block.shopify_attributes }}>
            {%- case block.type -%}
              {%- when 'brand_information' -%}
                {%- if block.settings.logo_image != blank -%}
                  <a href="{{ routes.root_url }}" class="ec-footer-logo-wrapper">
                    {%- assign logo_alt = block.settings.logo_image.alt | default: shop.name | escape -%}
                    <img
                      src="{{ block.settings.logo_image | image_url: width: 400 }}"
                      alt="{{ logo_alt }}"
                      class="ec-footer-logo-image"
                      style="max-width: {{ block.settings.logo_width }}px; height: auto;"
                      loading="lazy"
                    >
                  </a>
                {%- elsif settings.logo != blank -%}
                  <a href="{{ routes.root_url }}" class="ec-footer-logo-wrapper">
                    {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
                    <img
                      src="{{ settings.logo | image_url: width: 400 }}"
                      alt="{{ logo_alt }}"
                      class="ec-footer-logo-image"
                      style="max-width: {{ settings.logo_width | default: 150 }}px; height: auto;"
                      loading="lazy"
                    >
                  </a>
                {%- else -%}
                  <a href="{{ routes.root_url }}" class="ec-footer-logo">
                    {{ shop.name }}
                  </a>
                {%- endif -%}
                
                {%- if settings.brand_description != blank -%}
                  <div class="rte" style="color: #666; font-size: 1.4rem; line-height: 1.6; margin-bottom: 15px;">
                    {{ settings.brand_description }}
                  </div>
                {%- endif -%}

                <ul class="ec-footer-social-list" role="list">
                  {%- assign instagram_url = block.settings.instagram_link | default: settings.social_instagram_link -%}
                  {%- if instagram_url != blank -%}
                    <li>
                      <a href="{{ instagram_url }}" class="ec-footer-social-link" aria-label="Instagram">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none"></rect>
                          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" fill="none"></path>
                          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                        </svg>
                      </a>
                    </li>
                  {%- endif -%}
                  
                  {%- assign whatsapp_url = block.settings.whatsapp_link | default: settings.social_whatsapp_link -%}
                  {%- if whatsapp_url != blank -%}
                    <li>
                      <a href="{{ whatsapp_url }}" class="ec-footer-social-link" aria-label="WhatsApp">
                        <svg xmlns="http://www.w3.org/2000/svg" shape-rendering="geometricPrecision" text-rendering="geometricPrecision" image-rendering="optimizeQuality" fill-rule="evenodd" clip-rule="evenodd" viewBox="0 0 510 512.459"><path fill="#111B21" d="M435.689 74.468C387.754 26.471 324 .025 256.071 0 116.098 0 2.18 113.906 2.131 253.916c-.024 44.758 11.677 88.445 33.898 126.946L0 512.459l134.617-35.311c37.087 20.238 78.85 30.891 121.345 30.903h.109c139.949 0 253.88-113.917 253.928-253.928.024-67.855-26.361-131.645-74.31-179.643v-.012zm-179.618 390.7h-.085c-37.868-.011-75.016-10.192-107.428-29.417l-7.707-4.577-79.886 20.953 21.32-77.889-5.017-7.987c-21.125-33.605-32.29-72.447-32.266-112.322.049-116.366 94.729-211.046 211.155-211.046 56.373.025 109.364 22.003 149.214 61.903 39.853 39.888 61.781 92.927 61.757 149.313-.05 116.377-94.728 211.058-211.057 211.058v.011zm115.768-158.067c-6.344-3.178-37.537-18.52-43.358-20.639-5.82-2.119-10.044-3.177-14.27 3.178-4.225 6.357-16.388 20.651-20.09 24.875-3.702 4.238-7.403 4.762-13.747 1.583-6.343-3.178-26.787-9.874-51.029-31.487-18.86-16.827-31.597-37.598-35.297-43.955-3.702-6.355-.39-9.789 2.775-12.943 2.849-2.848 6.344-7.414 9.522-11.116s4.225-6.355 6.343-10.581c2.12-4.238 1.06-7.937-.522-11.117-1.584-3.177-14.271-34.409-19.568-47.108-5.151-12.37-10.385-10.69-14.269-10.897-3.703-.183-7.927-.219-12.164-.219s-11.105 1.582-16.925 7.939c-5.82 6.354-22.209 21.709-22.209 52.927 0 31.22 22.733 61.405 25.911 65.642 3.177 4.237 44.745 68.318 108.389 95.812 15.135 6.538 26.957 10.446 36.175 13.368 15.196 4.834 29.027 4.153 39.96 2.52 12.19-1.825 37.54-15.353 42.824-30.172 5.283-14.818 5.283-27.529 3.701-30.172-1.582-2.641-5.819-4.237-12.163-7.414l.011-.024z"/></svg>
                      </a>
                    </li>
                  {%- endif -%}

                  {%- assign facebook_url = block.settings.facebook_link | default: settings.social_facebook_link -%}
                  {%- if facebook_url != blank -%}
                    <li>
                      <a href="{{ facebook_url }}" class="ec-footer-social-link" aria-label="Facebook">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" fill="none"></path>
                        </svg>
                      </a>
                    </li>
                  {%- endif -%}
                </ul>

              {%- when 'link_list' -%}
                {%- if block.settings.heading != blank -%}
                  <h2 class="ec-footer-block-title">{{ block.settings.heading }}</h2>
                {%- endif -%}
                {%- if block.settings.menu != blank -%}
                  <ul class="ec-footer-block-menu">
                    {%- for link in block.settings.menu.links -%}
                      <li class="ec-footer-block-menu-item">
                        <a href="{{ link.url }}" class="ec-footer-block-menu-link">
                          {{ link.title }}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}

              {%- when 'text' -%}
                {%- if block.settings.heading != blank -%}
                  <h2 class="ec-footer-block-title">{{ block.settings.heading }}</h2>
                {%- endif -%}
                <div class="rte" style="color: #666; font-size: 1.4rem; line-height: 1.6;">
                  {{ block.settings.subtext }}
                </div>

              {%- when 'payment' -%}
                {%- if block.settings.heading != blank -%}
                  <h2 class="ec-footer-block-title">{{ block.settings.heading }}</h2>
                {%- endif -%}
                <ul class="ec-footer-payments" role="list">
                  {%- for type in shop.enabled_payment_types -%}
                    <li class="ec-footer-payment-item">
                      {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                    </li>
                  {%- endfor -%}
                </ul>

              {%- when 'image' -%}
                {%- if block.settings.image != blank -%}
                  <div style="max-width: {{ block.settings.image_width }}px;">
                    <img
                      src="{{ block.settings.image | image_url: width: 400 }}"
                      alt="{{ block.settings.image.alt | escape }}"
                      loading="lazy"
                      style="width: 100%; height: auto;"
                    >
                  </div>
                {%- endif -%}

            {%- endcase -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="ec-footer-bottom page-width">
    <div class="ec-footer-bottom-text">
      {%- if section.settings.company_address != blank -%}
        {{ section.settings.company_address }}
      {%- else -%}
        Somos Sonho LTA - Estrada do Campo D'areia, 182 - Pechincha - Rio de Janeiro/RJ - CEP: 22.743-310<br>
        CNPJ: 28.445.729/0081-75 | &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos os direitos reservados
      {%- endif -%}
    </div>
    
    <div class="ec-footer-bottom-agency">
      <svg viewBox="0 0 120 30" width="100" height="25" fill="currentColor" class="ec-footer-agency-logo">
        <text x="5" y="20" font-family="system-ui, -apple-system, sans-serif" font-weight="800" font-size="18" letter-spacing="-0.5px">wicomm</text>
        <text x="6" y="28" font-family="system-ui, -apple-system, sans-serif" font-weight="400" font-size="6" letter-spacing="1px" opacity="0.6">AGÊNCIA E-COMMERCE</text>
      </svg>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer Customizado",
  "blocks": [
    {
      "type": "brand_information",
      "name": "Marca e Redes Sociais",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo do Rodapé"
        },
        {
          "type": "range",
          "id": "logo_width",
          "min": 50,
          "max": 300,
          "step": 5,
          "unit": "px",
          "label": "Largura do Logo",
          "default": 150
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "Mostrar redes sociais"
        },
        {
          "type": "url",
          "id": "instagram_link",
          "label": "Link do Instagram"
        },
        {
          "type": "url",
          "id": "whatsapp_link",
          "label": "Link do WhatsApp"
        },
        {
          "type": "url",
          "id": "facebook_link",
          "label": "Link do Facebook"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu de Links",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Sobre Nós",
          "label": "Título"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Texto Livre",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Informação",
          "label": "Título"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "<p>Insira qualquer texto aqui para compartilhar detalhes com seus clientes.</p>",
          "label": "Texto"
        }
      ]
    },
    {
      "type": "payment",
      "name": "Formas de Pagamento",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Formas de Pagamento",
          "label": "Título"
        }
      ]
    },
    {
      "type": "image",
      "name": "Imagem",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem"
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 50,
          "max": 550,
          "step": 5,
          "unit": "px",
          "label": "Largura da Imagem",
          "default": 100
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de Cores",
      "default": "scheme-1"
    },
    {
      "type": "url",
      "id": "social_whatsapp_link",
      "label": "Link do WhatsApp"
    },
    {
      "type": "richtext",
      "id": "company_address",
      "label": "Endereço e Direitos Autorais",
      "default": "<p>Somos Sonho LTA - Estrada do Campo D'areia, 182 - Pechincha - Rio de Janeiro/RJ - CEP: 22.743-310<br>CNPJ: 28.445.729/0081-75 | &copy; 2026 Todos os direitos reservados</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaçamento Superior",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaçamento Inferior",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Footer Customizado",
      "blocks": [
        {
          "type": "brand_information"
        },
        {
          "type": "link_list"
        },
        {
          "type": "payment"
        }
      ]
    }
  ]
}
{% endschema %}
