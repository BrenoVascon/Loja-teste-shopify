{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient ec-img-with-products section-{{ section.id }}-padding" id="ec-img-with-products-{{ section.id }}">
  <div class="page-width">
    <div class="ec-img-with-products-grid ec-img-with-products-grid--{{ section.settings.image_position }}">
      
      <div class="ec-img-with-products-image-col">
        {%- if section.settings.image != blank -%}
          <div class="ec-img-with-products-image-wrapper">
            <img
              srcset="
                {%- if section.settings.image.width >= 165 -%}{{ section.settings.image | image_url: width: 165 }} 165w,{%- endif -%}
                {%- if section.settings.image.width >= 360 -%}{{ section.settings.image | image_url: width: 360 }} 360w,{%- endif -%}
                {%- if section.settings.image.width >= 533 -%}{{ section.settings.image | image_url: width: 533 }} 533w,{%- endif -%}
                {%- if section.settings.image.width >= 720 -%}{{ section.settings.image | image_url: width: 720 }} 720w,{%- endif -%}
                {%- if section.settings.image.width >= 1000 -%}{{ section.settings.image | image_url: width: 1000 }} 1000w,{%- endif -%}
                {{ section.settings.image | image_url }} {{ section.settings.image.width }}w
              "
              src="{{ section.settings.image | image_url: width: 720 }}"
              sizes="(min-width: 990px) 50vw, 100vw"
              alt="{{ section.settings.image.alt | escape }}"
              class="ec-img-with-products-image"
              loading="lazy"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
            >
          </div>
        {%- else -%}
          <div class="ec-img-with-products-image-placeholder">
            {{ 'collection-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <div class="ec-img-with-products-products-col">
        {%- if section.settings.title != blank -%}
          <h2 class="ec-img-with-products-heading inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.title }}
          </h2>
        {%- endif -%}
        
        <ec-products-slider class="ec-products-slider-wrapper">
          <button type="button" class="ec-slider-btn ec-slider-btn--prev" aria-label="Previous">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          
          <div class="ec-products-slider-viewport">
            <ul class="ec-products-slider-track grid" role="list">
              {%- assign products_found = false -%}
              {%- if section.settings.products != blank and section.settings.products.count > 0 -%}
                {%- assign products_found = true -%}
                {%- for product in section.settings.products -%}
                  <li class="ec-products-slider-slide grid__item">
                    {% render 'custom-card-product', card_product: product, section_id: section.id %}
                  </li>
                {%- endfor -%}
              {%- elsif section.settings.collection != blank and section.settings.collection.products.size > 0 -%}
                {%- assign products_found = true -%}
                {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
                  <li class="ec-products-slider-slide grid__item">
                    {% render 'custom-card-product', card_product: product, section_id: section.id %}
                  </li>
                {%- endfor -%}
              {%- endif -%}
              
              {%- if products_found == false -%}
                {%- for i in (1..3) -%}
                  <li class="ec-products-slider-slide grid__item">
                    <div style="background: #f4f4f4; padding: 20px; text-align: center; border-radius: 8px;">
                      <p>Produto de Exemplo {{ i }}</p>
                    </div>
                  </li>
                {%- endfor -%}
              {%- endif -%}
            </ul>
          </div>
          
          <button type="button" class="ec-slider-btn ec-slider-btn--next" aria-label="Next">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </ec-products-slider>
        
        <div class="ec-slider-dots-container"></div>
      </div>
      
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    class EcProductsSlider extends HTMLElement {
      constructor() {
        super();
      }
      connectedCallback() {
        const track = this.querySelector('.ec-products-slider-track');
        const prevBtn = this.querySelector('.ec-slider-btn--prev');
        const nextBtn = this.querySelector('.ec-slider-btn--next');
        const dotsContainer = this.parentElement.querySelector('.ec-slider-dots-container');
        if (!track) return;
        
        let snapPositions = [];
        
        const updateDots = () => {
          const maxScroll = track.scrollWidth - track.clientWidth;
          snapPositions = [];
          if (maxScroll > 0) {
            snapPositions = Array.from(track.children)
              .map(li => li.offsetLeft)
              .filter(offset => offset < maxScroll - 5);
            snapPositions.push(maxScroll);
          }
          
          const snapPoints = Math.max(0, snapPositions.length);
          if (dotsContainer && dotsContainer.children.length !== snapPoints) {
            dotsContainer.innerHTML = '';
            for (let i = 0; i < snapPoints; i++) {
              const btn = document.createElement('button');
              btn.className = 'ec-slider-dot' + (i === 0 ? ' is-active' : '');
              btn.dataset.slideIndex = i;
              dotsContainer.appendChild(btn);
            }
          }
        };

        updateDots();
        window.addEventListener('resize', updateDots);

        const getClosestIndex = (scrollLeft) => {
          let activeIndex = 0;
          let minDiff = Infinity;
          snapPositions.forEach((pos, index) => {
            const diff = Math.abs(pos - scrollLeft);
            if (diff < minDiff) {
              minDiff = diff;
              activeIndex = index;
            }
          });
          return activeIndex;
        };

        track.addEventListener('scroll', () => {
          if (!dotsContainer) return;
          const dots = dotsContainer.querySelectorAll('.ec-slider-dot');
          if (!dots.length || !snapPositions.length) return;
          const activeIndex = getClosestIndex(track.scrollLeft);
          dots.forEach((dot, index) => {
            dot.classList.toggle('is-active', index === activeIndex);
          });
        });

        if (dotsContainer) {
          dotsContainer.addEventListener('click', (e) => {
            if (e.target.classList.contains('ec-slider-dot')) {
              const index = parseInt(e.target.dataset.slideIndex);
              if (snapPositions[index] !== undefined) {
                track.scrollTo({ left: snapPositions[index], behavior: 'smooth' });
              }
            }
          });
        }

        if (prevBtn && nextBtn) {
          const navigate = (direction) => {
            if (!snapPositions.length) return;
            let currentIndex = getClosestIndex(track.scrollLeft);
            if (direction === 1 && currentIndex < snapPositions.length - 1) {
              currentIndex++;
            } else if (direction === -1 && currentIndex > 0) {
              currentIndex--;
            }
            track.scrollTo({ left: snapPositions[currentIndex], behavior: 'smooth' });
          };
          prevBtn.addEventListener('click', (e) => {
            e.preventDefault();
            navigate(-1);
          });
          nextBtn.addEventListener('click', (e) => {
            e.preventDefault();
            navigate(1);
          });
        }
      }
    }
    if (!customElements.get('ec-products-slider')) {
      customElements.define('ec-products-slider', EcProductsSlider);
    }
  });
</script>

{% schema %}
{
  "name": "Img with Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagem de Destaque"
    },
    {
      "type": "select",
      "id": "image_position",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ],
      "default": "left",
      "label": "Posição da Imagem no Desktop"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Produtos em Destaque",
      "limit": 12
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleção Alternativa (Se lista de produtos vazia)"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Produtos a mostrar (da Coleção Alternativa)"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Compre o Look",
      "label": "Título da Seção"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Pequeno"
        },
        {
          "value": "h1",
          "label": "Médio"
        },
        {
          "value": "h0",
          "label": "Grande"
        }
      ],
      "default": "h1",
      "label": "Tamanho do Título"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de Cores",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaçamento Superior",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaçamento Inferior",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Img with Products"
    }
  ]
}
{% endschema %}
