{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign products_to_display = section.settings.collection.all_products_count
  if section.settings.collection.all_products_count > section.settings.products_to_show
    assign products_to_display = section.settings.products_to_show
  endif
-%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient custom-featured-collection">
  <div class="collection section-{{ section.id }}-padding" id="collection-{{ section.id }}" data-id="{{ section.id }}">
    <div class="collection__title title-wrapper title-wrapper--no-top-margin page-width center">
      {%- if section.settings.title != blank -%}
        <h2 class="title inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      {%- endif -%}
    </div>

    <slider-component class="slider-mobile-gutter slider-component-desktop custom-slider-container">
      <div class="custom-slider-nav-wrapper">
        <button type="button" class="slider-button custom-slider-button custom-slider-button--prev" aria-label="Previous" aria-controls="Slider-{{ section.id }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon"><path d="M15 18l-6-6 6-6"/></svg>
        </button>

        <ul id="Slider-{{ section.id }}" class="grid product-grid contains-card grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down slider slider--desktop slider--tablet custom-exact-slider" role="list">
          {%- if section.settings.collection.products.size > 0 -%}
            {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
              <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="grid__item slider__slide">
                {% render 'custom-card-product', card_product: product, section_id: section.id %}
              </li>
            {%- endfor -%}
          {%- endif -%}
        </ul>

        <button type="button" class="slider-button custom-slider-button custom-slider-button--next" aria-label="Next" aria-controls="Slider-{{ section.id }}">
           <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
      
      <div class="custom-slider-dots">
         <!-- Dots generated via JS -->
      </div>
    </slider-component>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (!customElements.get('custom-card-variants')) {
      customElements.define('custom-card-variants', class extends HTMLElement {
        constructor() {
          super();
          this.sizeButtons = this.querySelectorAll('.size-option');
          this.hiddenInput = this.querySelector('.product-variant-id');
          this.submitBtn = this.querySelector('.custom-quick-add-submit');
          this.productLinks = this.querySelectorAll('.product-link');
          this.favoriteBtn = this.querySelector('.custom-card-favorite');

          if (this.favoriteBtn) {
            this.favoriteBtn.addEventListener('click', (e) => {
              e.preventDefault();
              e.stopPropagation();
              this.favoriteBtn.classList.toggle('is-active');
            });
          }

          this.sizeButtons.forEach(btn => {
            btn.addEventListener('click', (e) => {
              e.preventDefault();
              if(btn.hasAttribute('disabled')) return;

              this.sizeButtons.forEach(b => b.classList.remove('is-selected'));
              btn.classList.add('is-selected');
              
              const variantId = btn.dataset.variantId;
              if (this.hiddenInput) {
                this.hiddenInput.value = variantId;
                this.hiddenInput.disabled = false;
                this.submitBtn.disabled = false;
              }

              const productUrl = btn.dataset.url;
              if (productUrl) {
                 this.productLinks.forEach(link => {
                   link.href = productUrl;
                 });
              }
            });
          });
        }
      });
    }

    const sliders = document.querySelectorAll('.custom-slider-container');
    sliders.forEach(slider => {
      const ul = slider.querySelector('ul.slider');
      const dotsContainer = slider.querySelector('.custom-slider-dots');
      if(!ul || !dotsContainer) return;

      let snapPositions = [];

      const updateDots = () => {
         const maxScroll = ul.scrollWidth - ul.clientWidth;
         snapPositions = [];
         
         if (maxScroll > 0) {
            snapPositions = Array.from(ul.children)
               .map(li => li.offsetLeft)
               .filter(offset => offset < maxScroll - 5);
            snapPositions.push(maxScroll);
         }
         
         const snapPoints = Math.max(0, snapPositions.length);
         if (dotsContainer.children.length !== snapPoints) {
            dotsContainer.innerHTML = '';
            for(let i = 0; i < snapPoints; i++) {
               const btn = document.createElement('button');
               btn.className = 'custom-slider-dot' + (i === 0 ? ' is-active' : '');
               btn.dataset.slideIndex = i;
               dotsContainer.appendChild(btn);
            }
         }
      };

      updateDots();
      window.addEventListener('resize', updateDots);

      const getClosestIndex = (scrollLeft) => {
         let activeIndex = 0;
         let minDiff = Infinity;
         snapPositions.forEach((pos, index) => {
            const diff = Math.abs(pos - scrollLeft);
            if (diff < minDiff) {
               minDiff = diff;
               activeIndex = index;
            }
         });
         return activeIndex;
      };

      ul.addEventListener('scroll', () => {
         const dots = dotsContainer.querySelectorAll('.custom-slider-dot');
         if (!dots.length || !snapPositions.length) return;
         
         const activeIndex = getClosestIndex(ul.scrollLeft);
         
         dots.forEach((dot, index) => {
            dot.classList.toggle('is-active', index === activeIndex);
         });
      });

      dotsContainer.addEventListener('click', (e) => {
         if (e.target.classList.contains('custom-slider-dot')) {
            const index = parseInt(e.target.dataset.slideIndex);
            if (snapPositions[index] !== undefined) {
               ul.scrollTo({ left: snapPositions[index], behavior: 'smooth' });
            }
         }
      });

      const prevBtn = slider.querySelector('.custom-slider-button--prev');
      const nextBtn = slider.querySelector('.custom-slider-button--next');

      if (prevBtn && nextBtn) {
          const navigate = (direction) => {
              if (!snapPositions.length) return;
              let currentIndex = getClosestIndex(ul.scrollLeft);
              
              if (direction === 1 && currentIndex < snapPositions.length - 1) {
                  currentIndex++;
              } else if (direction === -1 && currentIndex > 0) {
                  currentIndex--;
              }
              ul.scrollTo({ left: snapPositions[currentIndex], behavior: 'smooth' });
          };

          prevBtn.addEventListener('click', (e) => {
              e.preventDefault();
              navigate(-1);
          });

          nextBtn.addEventListener('click', (e) => {
              e.preventDefault();
              navigate(1);
          });
      }
    });
  });
</script>

{% schema %}
{
  "name": "Custom Featured Coll",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 25,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Favoritos da Semana",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Desktop columns"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "Mobile columns",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Custom Featured Coll"
    }
  ]
}
{% endschema %}
